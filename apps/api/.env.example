INSPIRATION_IMAGE_PROVIDER=openai
INSPIRATION_VISION_PROVIDER=openai
INSPIRATION_IMAGE_CACHE_ENABLED=true
INSPIRATION_IMAGE_CACHE_DIR=cache/inspiration/images

INSPIRATION_OPENAI_IMAGE_API_URL=https://api.openai.com/v1/images/generations
INSPIRATION_OPENAI_IMAGE_API_KEY=
INSPIRATION_OPENAI_IMAGE_MODEL=gpt-image-1
INSPIRATION_OPENAI_IMAGE_SIZE=1024x1024
INSPIRATION_OPENAI_IMAGE_QUALITY=medium
INSPIRATION_OPENAI_IMAGE_STYLE=
INSPIRATION_OPENAI_IMAGE_TIMEOUT_MS=30000
INSPIRATION_OPENAI_IMAGE_N=1

INSPIRATION_GOOGLE_IMAGE_API_URL=https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict
INSPIRATION_GOOGLE_IMAGE_API_KEY=
INSPIRATION_GOOGLE_IMAGE_MODEL=imagen-4.0-generate-001
INSPIRATION_GOOGLE_IMAGE_SIZE=
INSPIRATION_GOOGLE_IMAGE_ASPECT_RATIO=1:1
INSPIRATION_GOOGLE_IMAGE_TIMEOUT_MS=30000
INSPIRATION_GOOGLE_IMAGE_N=1

INSPIRATION_OPENAI_VISION_API_URL=https://api.openai.com/v1/responses
INSPIRATION_OPENAI_VISION_API_KEY=
INSPIRATION_OPENAI_VISION_MODEL=gpt-4.1-mini
INSPIRATION_OPENAI_VISION_TIMEOUT_MS=30000

INSPIRATION_GOOGLE_VISION_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent
INSPIRATION_GOOGLE_VISION_API_KEY=
INSPIRATION_GOOGLE_VISION_MODEL=gemini-2.5-flash
INSPIRATION_GOOGLE_VISION_TIMEOUT_MS=30000

INSPIRATION_CONVERSION_PROMPT_PATH=cmd/server/inspiration-conversion-prompt.txt

CEREBRAS_API_KEY=
CEREBRAS_API_URL=https://api.cerebras.ai/v1/chat/completions
CEREBRAS_MODEL=llama3.1-8b
#CEREBRAS_MODEL=gpt-oss-120b
CEREBRAS_REASONING_EFFORT=
CEREBRAS_TEMPERATURE=
CEREBRAS_TIMEOUT_MS=20000
COMPONENT_REGISTRY_PATH=data/component-registry.json
PORT=3000
CORS_ALLOWED_ORIGIN=http://localhost:5173
GENERATION_REPAIR_ENABLED=false
